{
  "version": 2,
  "experimentalServices": {
    "backend": {
      "entrypoint": "backend/app.py",
      "routePrefix": "/api",
      "framework": "flask"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
